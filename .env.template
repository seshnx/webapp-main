# Environment Variables Template
#
# Pull actual values from Vercel:
#   npm run pull-env:vercel
#
# Or run: vercel env pull .env

# ================================
# DATABASE
# ================================
# MongoDB connection (for social features, booking metadata)
VITE_MONGODB_CONNECTION_STRING=
VITE_MONGODB_DB_NAME=seshnx

# Neon PostgreSQL connection (for legal/financial data)
VITE_NEON_CONNECTION_STRING=
DATABASE_URL=

# ================================
# AUTHENTICATION (Clerk)
# ================================
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_SIGN_OUT_URL=/sign-out
VITE_CLERK_AFTER_SIGN_IN_URL=/
VITE_CLERK_AFTER_SIGN_UP_URL=/

# ================================
# CONVEX (Real-time)
# ================================
VITE_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# ================================
# STORAGE (Vercel Blob)
# ================================
BLOB_READ_WRITE_TOKEN=

# ================================
# PAYMENTS (Stripe)
# ================================
VITE_STRIPE_TEST_KEY=

# ================================
# ERROR TRACKING (Sentry)
# ================================
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ================================
# OTHER
# ================================
NODE_ENV=development
