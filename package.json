{
  "name": "seshnx-webapp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server-mock-api.js",
    "dev:full": "concurrently \"npm:dev:api\" \"npm:dev\"",
    "prebuild": "npx convex codegen && node scripts/validate-env.cjs .env",
    "build": "vite build",
    "build:vercel": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "update-social-imports": "node scripts/update-social-imports.js",
    "pull-env": "node scripts/pull-env-vercel.js",
    "pull-env:vercel": "vercel env pull .env",
    "fix-env": "node scripts/fix-env-vars.js",
    "validate-env": "node scripts/validate-env.cjs .env",
    "validate-env:local": "node scripts/validate-env.cjs .env.local",
    "fix-env:auto": "node scripts/fix-env.cjs .env"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@clerk/backend": "^3.0.1",
    "@clerk/react": "^6.0.1",
    "@hookform/resolvers": "^3.3.4",
    "@sentry/react": "^8.0.0",
    "@stripe/react-stripe-js": "^2.5.0",
    "@stripe/stripe-js": "^3.0.7",
    "@tanstack/react-query": "^5.90.21",
    "@vercel/analytics": "^2.0.0",
    "@vercel/blob": "^2.3.1",
    "clsx": "^2.1.0",
    "convex": "^1.35.1",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "pannellum": "^2.5.7",
    "pg": "^8.20.0",
    "react": "^18.2.0",
    "react-big-calendar": "^1.13.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.2",
    "react-hot-toast": "^2.4.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.22.1",
    "stripe": "^14.21.0",
    "svix": "^1.86.0",
    "tailwind-merge": "^2.2.1",
    "wavesurfer.js": "^7.7.0",
    "zod": "^3.22.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@sentry/vite-plugin": "^4.9.1",
    "@types/leaflet": "^1.9.21",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^20.19.37",
    "@types/react": "^18.2.56",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^18.2.19",
    "@types/react-router-dom": "^5.3.3",
    "@types/wavesurfer.js": "^6.0.12",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "express": "^5.2.1",
    "globals": "^15.15.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "overrides": {
    "@rollup/plugin-terser": "^1.0.0"
  }
}
