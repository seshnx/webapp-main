# SeshNx Environment Variables Example
# ===================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local or .env files to git!
#
# Quick setup:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your values
# 3. Run: npm run dev
#
# Validate your env file:
#   node scripts/validate-env.cjs .env.local
#
# Fix common issues:
#   node scripts/fix-env.cjs .env.local

# ================================
# REQUIRED VARIABLES
# ================================

# Clerk Authentication (REQUIRED)
# Get these from: https://dashboard.clerk.com/
# IMPORTANT: Do NOT add extra quotes or escaped newlines!
# WRONG: "pk_test_...\n"
# WRONG: ""pk_test_..."
# CORRECT: pk_test_...
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret_here

# Clerk URLs (Optional - can use defaults)
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_SIGN_OUT_URL=/sign-out
VITE_CLERK_AFTER_SIGN_IN_URL=/
VITE_CLERK_AFTER_SIGN_UP_URL=/

# Neon PostgreSQL Database (REQUIRED)
# Get connection string from: https://console.neon.tech/
# This is your primary database for all core data
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host/database?sslmode=require

# Convex Real-time (REQUIRED for real-time features)
# Get this from: https://dashboard.convex.dev/
# Used for chat, presence, and real-time updates
VITE_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=your_convex_deploy_key_here

# ================================
# OPTIONAL BUT RECOMMENDED
# ================================

# MongoDB (Optional - for social features metadata)
# Get connection string from: https://www.mongodb.com/atlas
# Client-side variables (for browser access)
VITE_MONGODB_CONNECTION_STRING=mongodb+srv://user:password@host/database
VITE_MONGODB_DB_NAME=sesh-nx
# Server-side variables (for API routes - REQUIRED for production)
MONGODB_URI=mongodb+srv://user:password@host/database
MONGODB_DB_NAME=sesh-nx

# Vercel Blob Storage (Optional - for file uploads)
# Get token from: https://vercel.com/dashboard
BLOB_READ_WRITE_TOKEN=vercel_blob_token_here
VITE_BLOB_READ_WRITE_TOKEN=vercel_blob_token_here

# Stripe Payments (Optional - for payment processing)
# Get keys from: https://dashboard.stripe.com/
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_here

# Sentry Error Tracking (Optional - for production monitoring)
# Get DSN from: https://sentry.io/
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_org_name
SENTRY_PROJECT=your_project_name

# Stack Auth (Optional - alternative authentication)
# Get keys from: https://stack.auth.com/
VITE_STACK_PROJECT_ID=your_stack_project_id
VITE_STACK_PUBLISHABLE_CLIENT_KEY=your_stack_client_key
STACK_SECRET_SERVER_KEY=your_stack_secret_key

# ================================
# DEVELOPMENT ONLY
# ================================

# Node environment
NODE_ENV=development

# API endpoint (if using custom API)
VITE_API_ENDPOINT=https://api.seshnx.com

# Supabase (Legacy - deprecated, migrate to Neon)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# PostgreSQL connection details (optional - DATABASE_URL is preferred)
PGHOST=your-neon-host
PGDATABASE=your-database-name
PGUSER=your-username
PGPASSWORD=your-password

# ================================
# VERCEL-SPECIFIC
# ================================

# These are automatically set by Vercel
# Do not set these manually in .env.local
VERCEL_OIDC_TOKEN=auto-generated-by-vercel

# ================================
# VALIDATION CHECKLIST
# ================================
#
# Before running the app, verify:
#
# [ ] All Clerk keys are present and have correct format
# [ ] No extra quotes around values (e.g., "value" → value)
# [ ] No escaped newlines at end (e.g., value\n" → value")
# [ ] No empty double quote prefix (e.g., ""value → value)
# [ ] DATABASE_URL is a valid PostgreSQL connection string
# [ ] VITE_CONVEX_URL is a valid Convex deployment URL
#
# Run validation:
#   node scripts/validate-env.cjs .env.local
#
# If validation fails, run auto-fix:
#   node scripts/fix-env.cjs .env.local
#
# ================================
# COMMON ISSUES
# ================================
#
# Issue 1: "Cannot initialize Smart CAPTCHA widget"
# Cause: Extra quotes around Clerk keys
# Fix: Remove quotes from VITE_CLERK_PUBLISHABLE_KEY
#
# Issue 2: "Database connection failed"
# Cause: Invalid DATABASE_URL format
# Fix: Verify connection string format: postgresql://user:pass@host/db?sslmode=require
#
# Issue 3: "Convex not available"
# Cause: Missing or invalid VITE_CONVEX_URL
# Fix: Ensure URL starts with https:// and ends with .convex.cloud
#
# ================================
# SECURITY NOTES
# ================================
#
# 1. NEVER commit .env.local or .env files to git
# 2. Always use .gitignore to exclude these files
# 3. Use different keys for development and production
# 4. Rotate keys if they're accidentally exposed
# 5. Use test keys for development (pk_test_, sk_test_)
# 6. Never share secret keys (CLERK_SECRET_KEY, STRIPE_SECRET_KEY)
#
# ================================
# GETTING YOUR KEYS
# ================================
#
# Clerk (Authentication):
# 1. Go to https://dashboard.clerk.com/
# 2. Select your application
# 3. Go to "API Keys" in the left sidebar
# 4. Copy Publishable Key and Secret Key
# 5. For webhooks, go to "Webhooks" and create a webhook to get the secret
#
# Neon (Database):
# 1. Go to https://console.neon.tech/
# 2. Select your project
# 3. Go to "Connection Details"
# 4. Copy the connection string (use "Pooling" for production)
#
# Convex (Real-time):
# 1. Go to https://dashboard.convex.dev/
# 2. Select your project
# 3. Go to "Settings"
# 4. Copy the Deployment URL
# 5. For deployment, go to "Deployment Keys" to create a deploy key
#
# Vercel Blob (Storage):
# 1. Go to https://vercel.com/dashboard
# 2. Select your project
# 3. Go to "Storage" → "Create Blob Store"
# 4. Copy the read/write token
#
# Stripe (Payments):
# 1. Go to https://dashboard.stripe.com/
# 2. Go to "Developers" → "API keys"
# 3. Copy the publishable key (starts with pk_)
# 4. Copy the secret key (starts with sk_)
# 5. Make sure you're in "Test mode" for development
